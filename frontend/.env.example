# ─── Backend API ────────────────────────────────────
VITE_API_URL=https://your-app.onrender.com/api

# ─── Google Auth ────────────────────────────────────
VITE_GOOGLE_AUTH_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# ─── Google Places (browser-side autocomplete) ──────
VITE_GOOGLE_PLACES_API_KEY=<your-google-places-api-key>

# ─── Mapbox (optional — trip map) ───────────────────
VITE_MAPBOX_ACCESS_TOKEN=<your-mapbox-token>
